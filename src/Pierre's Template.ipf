Proc normmat3d(name)
	String name
	Prompt name,"Enter the name of the matrix"
	Pauseupdate;Silent 1
	Variable i,j
	i=0
	Do
		if(mod(i,5)==0)
			print i,"/",dimsize($name,0)
		Endif
		j=0
		Do
			Make/O/N=(dimsize($name,1)) thiswave
			thiswave[]=$name[i][p][j]
			Wavestats/Q thiswave
			thiswave[]/=V_avg
			$name[i][][j]=thiswave[q]
			j+=1
		While(j<dimsize($name,2))
		i+=1
	While(i<dimsize($name,0))
End
