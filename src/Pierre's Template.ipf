Proc mkfit_ini_tbl()
	PauseUpdate
	Silent 1
	Make/O/N=1 pk_type
	Make/O/N=1 pk_position_ini
	Make/O/N=1 pk_width_ini
	Make/O/N=1 pk_height_ini
	edit pk_type,pk_position_ini,pk_width_ini,pk_height_ini
	End
