//********************************************************************************************************************************
Proc finddispersion_min(name,peak_name)
	String name
	String peak_name
	Prompt name,"Enter the name of the cut"
	Prompt peak_name,"Enter the name of the peak"
	PauseUpdate
	Silent 1
	String name_x,name_y
	Variable i,j
	name_x="x_"+name+"pk"+peak_name
	name_y="y_"+name+"pk"+peak_name
	Make/O/N=(pcsr(B)-pcsr(A)+1) $name_x
	Make/O/N=(pcsr(B)-pcsr(A)+1) $name_y
	i=pcsr(A)
	j=0
	Do
		Make/O/N=(dimsize($name,1)) thiswave
		Setscale/p x,dimoffset($name,1),dimdelta($name,1),""thiswave
		thiswave[]=$name[i][p]
		Wavestats/Q/R=(vcsr(A),vcsr(B)) thiswave
		$name_y[j]=V_minloc
		$name_x[j]=xcsr(A)+j*dimdelta($name,0)
		i+=1
		j+=1
	While(i<pcsr(B)+1)
	Killwaves thiswave
	Appendtograph $name_y vs $name_x
End
