Function PopMenuProc(ctrlName,popNum,popStr) : PopupMenuControl   //type of data menu
	String ctrlName
	Variable popNum
	String popStr
	Variable/G typeofdata
	typeofdata=popNum
	print popStr
End

Function PopMenuProc_2(ctrlName,popNum,popStr) : PopupMenuControl  //inverse the color
	String ctrlName
	Variable popNum
	String popStr
	Variable/G colorinverseedc
	colorinverseedc=popNum
End

Function PopMenuProc_1(ctrlName,popNum,popStr) : PopupMenuControl
	String ctrlName
	Variable popNum
	String popStr
	Variable/G colorsetedc
	colorsetedc=popNum
End

