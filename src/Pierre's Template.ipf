Proc remove60(sstart,eend)
	Variable sstart
	Variable eend
	Pauseupdate
	Silent 1
	String thisname
	Variable i
	i=sstart
	Do
		thisname="data"+num2str(i)
		$thisname[60][]=0.5*($thisname[59][q]+$thisname[61][q])
		i+=1
	While(i<eend+1)
End
