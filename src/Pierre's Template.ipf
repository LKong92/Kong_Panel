	Variable i,j
	j=0
	i=100
	Do
		name_of_graph="graph"+num2str(i)
		Dowindow/F $name_of_graph
//		TextBox/C/N=text0/F=0/S=3/M/H={0,1,10}/A=MC "\Z12\F'Symbol'G\F'Arial'-Y "+num2str(od71energy_of_data3[j])+" eV"
		TextBox/C/N=text0/F=0/S=3/M/H={0,1,10}/A=MC "\Z12M-Y "+num2str(od71energy_of_data4[j])+" eV"
