Function findinglengthforCsrslicer(interpntsforCsrslicer)
	Wave interpntsforCsrslicer
	Variable length
	length=sqrt((interpntsforCsrslicer[0][0]-interpntsforCsrslicer[1][0])^2+(interpntsforCsrslicer[0][1]-interpntsforCsrslicer[1][1])^2)
	Return length
End

