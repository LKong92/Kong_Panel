Proc ConvtAll()
	PauseUpdate
	Silent 1
	Variable/G typeofdata
	If(typeofdata==1)
		ConvtAllpxt()
	Endif
	If(typeofdata==2)
		ConvtAlltxt()
	Endif
	If(typeofdata==3)
		ConvtAlldat()
	Endif
	If(typeofdata==4)
		ConvtAllA1()
	Endif
End

Proc ConvtAllA1()
	PauseUpdate
	Silent 1
	Variable i
	i=1
	Do
		gv_groupNum=i
		ConvtOneProcA1()
		i+=1
	While(i<dimsize(File_name,0))
End

