//********************************************************************************************************************************
Proc doallcvt2k()
	PauseUpdate
	Silent 1
	String name
	Variable i
	i=0
	Do
		name="cut"+num2str(phiindex[i])
		rescale_pi(name,1,+1.2)
		cvt2ek_pi(name,1,69.2,phiindex[i]+11)
//		rescale_pi(name,1,-6.9)
//		cvt2ek_pi(name,1,17.658,phiindex[i]-7)
//		rescale_pi(name,1,-11)
//		cvt2ek_pi(name,1,17.658,phiindex[i]-13)
		i+=1
	While(i<dimsize(phiindex,0))
End
//********************************************************************************************************************************
Proc initmat3d()
	pauseupdate
	silent 1
	Variable/G mat3d_energy_center,mat3d_energy_wide,mat3d_energy_increment
	Variable/G mat3d_energy_min,mat3d_energy_max
	mat3d_energy_min=dimoffset(mat3d,1)
	mat3d_energy_max=dimoffset(mat3d,1)+(dimsize(mat3d,1)-1)*dimdelta(mat3d,1)
	mat3d_energy_center=mat3d_energy_min
	mat3d_energy_wide=0.04
	mat3d_energy_increment=0.01
	Make/O/N=(dimsize(mat3d,0),dimsize(mat3d,2)) mat3d_energy_plot
	Setscale/P x,dimoffset(mat3d,0),dimdelta(mat3d,0),""mat3d_energy_plot
	Setscale/P y,dimoffset(mat3d,2),dimdelta(mat3d,2),""mat3d_energy_plot
	mat3d_energy_plot[][]=0
End
//********************************************************************************************************************************
