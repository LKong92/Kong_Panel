Proc getslopes()
	PauseUpdate
	Silent 1
	String newwave
	Variable i,j
	Make/O/N=11 slopesabove
	Make/O/N=11 b_above
	Make/O/N=11 slopesabove_err
	Make/O/N=11 b_above_err
	Setscale/P x,3,1,""slopesabove
	Setscale/P x,3,1,""b_above
	i=3
	Do
		newwave="DOSabove"+num2str(i)
		CurveFit/Q/NTHR=0 line  $newwave[0,90] /D
		slopesabove[i-3]=W_coef[1]
		b_above[i-3]=W_coef[0]
		slopesabove_err[i-3]=W_sigma[1]
		b_above_err[i-3]=W_sigma[0]
		i+=1
	While(i<dimsize(File_name,0)-2)
End
