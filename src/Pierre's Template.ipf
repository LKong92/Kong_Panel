Proc initmat3dk()
	pauseupdate
	silent 1
	Variable/G mat3dk_energy_center,mat3dk_energy_wide,mat3dk_energy_increment
	Variable/G mat3dk_energy_min,mat3dk_energy_max
	mat3dk_energy_min=dimoffset(mat3dk,2)
