Function ButtonProc_openbkgndremover(ctrlName) : ButtonControl
	String ctrlName
	IF(Wintype("background_remover")==1)
		Dowindow/F background_remover
		Else
			Make/O/N=(2,2) blank_bkgndremover
			blank_bkgndremover[][]=NaN
			Execute "background_remover()"
	Endif
End
