	iend=19
	jini=321
	jend=360
	Make/O/N=(dimsize(data5,0)) Nabove
	Nabove[]=0
	totalnum=0
	i=iini
	Do
		thisname="data"+num2str(i)
		j=jini
		Do
			Nabove[]+=$thisname[p][j]
			totalnum+=1
			j+=1
		While(j<jend+1)
		i+=1
	While(i<iend+1)
	Nabove[]/=totalnum
	Display Nabove
End
