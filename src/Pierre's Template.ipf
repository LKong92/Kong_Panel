Function ButtonProc_colorbwr(ctrlName) : ButtonControl
	String ctrlName
	Execute "colorbwr()"
end
Proc colorbwr()
	ModifyImage $topgraphimage ctab= {*,*,root:Packages:NewColortable:Colorcet_diverging_bwr_20_95_c54,0}
	topgraphcolor = "Colorcet_diverging_bwr_20_95_c54"
End
//
//
//$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$$
