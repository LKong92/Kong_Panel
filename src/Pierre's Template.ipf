//**********************************************************************************************************************
Proc sub_bline_pi_matrix(matname,numbpnts)
	String matname
	Variable numbpnts
	Prompt matname,"Name of the matrix"
	Prompt numbpnts,"Number of points"
	PauseUpdate; Silent 1
	Variable i
	i=0
	Do
		Make/O/N=(dimsize($matname,1)) thiswave
		setscale/P x,dimoffset($matname,1),dimdelta($matname,1),""thiswave
		sub_bline_pi(thiswave,numbpnts)
		i+=1
	While(i<dimsize($matname,0))
End
