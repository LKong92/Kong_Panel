Macro  MakeEfMdcTable()
	pauseupdate
	silent 1
	if(  2==winType("efmdc_table"))
		DoWindow /F efmdc_table
	endif
	if(  0==wintype("efmdc_table"))
		string efmi="efmdcindex"
		if(!waveexists($efmi))
			make/n=1 $efmi
		endif
		string efmt="efmdctemp"
		if(!waveexists($efmt))
			make/n=1 $efmt
		endif
		string efmw="efmdcw"
		if(!waveexists($efmw))
			make/n=1 $efmw
		endif
		string efmp="efmdcpara"
		if(!waveexists($efmp))
			make/n=5 $efmp
		endif
		string efmn="efmdcpn"
		if(!waveexists($efmn))
			make/t/n=5 $efmn
			$efmn[0]="y0"
			$efmn[1]="a"
			$efmn[2]="posi"
			$efmn[3]="width"
			$efmn[4]="b"
		endif
		edit $efmi,$efmt,$efmw,$efmn,$efmp as "efmdc_table"
		DoWindow /C efmdc_table
	endif
End

