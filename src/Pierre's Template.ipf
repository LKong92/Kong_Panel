		Endif
		if(hv_of_wave[i]==73)
			thiswave=name_of_wave[i]
			Setscale/P x,dimoffset($thiswave,0)-68.565,dimdelta($thiswave,0),""$thiswave
		Endif
		if((hv_of_wave[i]==75)&&(cmpstr(thisname[1],"p")==0))
			thiswave=name_of_wave[i]
			Setscale/P x,dimoffset($thiswave,0)-70.674,dimdelta($thiswave,0),""$thiswave
		Endif
		if((hv_of_wave[i]==75)&&(cmpstr(thisname[1],"p")!=0))
			thiswave=name_of_wave[i]
			Setscale/P x,dimoffset($thiswave,0)-70.57,dimdelta($thiswave,0),""$thiswave
		Endif
		i+=1
	While(i<dimsize(name_of_wave,0))
End
