		SetAxis bottom 0,sqrt(3/2)
		ModifyGraph manTick(left)={0,0.25,0,2},manMinor(left)={4,0};DelayUpdate
		ModifyGraph manTick(bottom)={0,0.25,0,2},manMinor(bottom)={4,0}
	Endif
	If(popNum==5)
		SetAxis left -sqrt(3/2),sqrt(3/2);DelayUpdate
		SetAxis bottom -sqrt(3/2),sqrt(3/2)
		ModifyGraph manTick(left)={0,0.5,0,1},manMinor(left)={4,0};DelayUpdate
		ModifyGraph manTick(bottom)={0,0.5,0,1},manMinor(bottom)={4,0}
	Endif
	If(popNum==6)
		SetAxis left -2.5*sqrt(3/2),2.5*sqrt(3/2);DelayUpdate
		SetAxis bottom -2.5*sqrt(3/2),2.5*sqrt(3/2)
		ModifyGraph manTick(left)={0,1,0,0},manMinor(left)={4,0};DelayUpdate
		ModifyGraph manTick(bottom)={0,1,0,0},manMinor(bottom)={4,0}
	Endif
	If(popNum==7)
		SetAxis left -4*sqrt(3/2),4*sqrt(3/2);DelayUpdate
		SetAxis bottom -4*sqrt(3/2),4*sqrt(3/2)
		ModifyGraph manTick(left)={0,2,0,0},manMinor(left)={4,0};DelayUpdate
		ModifyGraph manTick(bottom)={0,2,0,0},manMinor(bottom)={4,0}
	Endif
End

