Proc pseudogap_profile(gap,temperature)
	Variable gap=0.2
	Variable temperature=0.01
	Prompt gap,"Enter the impurity gap"
	Prompt temperature,"Enter the temperature of the profile"
	PauseUpdate
	Silent 1
	Make/O/N=5 coeff
	Make/O/N=(dimsize(Akw,1)) pg_profile
	Setscale/P x, dimoffset(Akw,1),dimdelta(Akw,1),""pg_profile
	coeff[0]=0
	coeff[1]=1
	coeff[2]=-gap/2
	coeff[3]=gap/2
	coeff[4]=temperature
	pg_profile[]=fermigap(coeff,dimoffset(pg_profile,0)+p*dimdelta(pg_profile,0))
End
