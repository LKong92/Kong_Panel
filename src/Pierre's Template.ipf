	silent 1
	Variable/G mat3dVD_energy_center,mat3dVD_energy_wide,mat3dVD_energy_increment
	Variable/G mat3dVD_energy_min,mat3dVD_energy_max
	mat3dVD_energy_min=dimoffset(mat3dVD,1)
	mat3dVD_energy_max=dimoffset(mat3dVD,1)+(dimsize(mat3dVD,1)-1)*dimdelta(mat3dVD,1)
	mat3dVD_energy_center=mat3dVD_energy_min
	mat3dVD_energy_wide=0.04
	mat3dVD_energy_increment=0.01
	Make/O/N=(dimsize(mat3dVD,0),dimsize(mat3d,2)) mat3dVD_energy_plot
	Setscale/P x,dimoffset(mat3dVD,0),dimdelta(mat3d,0),""mat3dVD_energy_plot
	Setscale/P y,dimoffset(mat3dVD,2),dimdelta(mat3d,2),""mat3dVD_energy_plot
	mat3dVD_energy_plot[][]=0
End
