	Make/O/N=(dimsize(indexgapoutter,0),dimsize(symEDC_kf0,0)) matkfout
	setscale/P y,dimoffset(symEDC_kf0,0),dimdelta(symEDC_kf0,0),""matkfout
	i=0
	Do
		thisname="symEDC_kf"+num2str(indexgapoutter[i])
		matkfout[i][]=$thisname[q]
		i+=1
