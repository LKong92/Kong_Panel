Proc plot_cone25K()
	PauseUpdate;Silent 1
	string thisname
	String nameofwindow
	Variable i
	i=-30
	Do
		IF(i<0)
			thisname="cone_"+num2str(ABS(i))+"deg"
			nameofwindow=thisname+"_graph"
			Else
				thisname="cone"+num2str(ABS(i))+"deg"
				nameofwindow=thisname+"_graph"
		Endif
