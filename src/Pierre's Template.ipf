	Endif
	if(Wintype("badslices")==2)
		Dowindow/F badslices
	Endif
End
//********************************************************************************************************************************
Function give_slope(x1,y1,x2,y2)
	Variable x1,y1,x2,y2
	return ((y2-y1)/(x2-x1))
End
//********************************************************************************************************************************
Function give_b(m,x1,y1)
	Variable m,x1,y1
	return (y1-m*x1)
End
