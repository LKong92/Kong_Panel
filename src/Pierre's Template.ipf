		Button button111 disable=1
		Button button114 disable=1
		Button button115 disable=1

		//List
		Button button96 disable=1
		Button button97 disable=1
		Button button98 disable=1
		Button button99 disable=1
		Button button109 disable=1
		Button button110 disable=1
		Valdisplay Valdisp0 disable=1
		Valdisplay Valdisp1 disable=1
		Checkbox check0 disable=1
		Checkbox check1 disable=1
		Checkbox check2 disable=1
		Checkbox check3 disable=1
		Checkbox check4 disable=1
		Checkbox check5 disable=1

		//For Old, New and hv only
		Button button88 disable=0
	Endif
	return 0
End
