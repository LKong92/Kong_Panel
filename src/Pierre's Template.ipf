	Button button3,fSize=15,fStyle=16,fColor=(16385,16388,65535)
	Button button4,pos={143,204},size={25,20},proc=Button_Help_Plot_EDC,title="\\K(65535,65535,65535)?"
	Button button4,fSize=15,fStyle=16,fColor=(16385,16388,65535)
	Button button5,pos={143,236},size={25,20},proc=Button_Help_Plot_MDC,title="\\K(65535,65535,65535)?"
