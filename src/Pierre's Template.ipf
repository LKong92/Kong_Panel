		thisk=i*deltak
		index_old=Floor(((thisk-sqrt(2))-dimoffset($matGM,0))/(dimdelta($matGM,0)))
		factor_up=((thisk-sqrt(2))-dimoffset($matGM,0)-index_old*dimdelta($matGM,0))/dimdelta($matGM,0)
