	Setscale/P x,dimoffset($thiswave,0),dimdelta($thiswave,0),""$newreal
	Setscale/P x,dimoffset($thiswave,0),dimdelta($thiswave,0),""$newim
	print dimsize($thiswave,0),
	$newreal[]=real($thiswave[p])
	$newim[]=imag($thiswave[p])
End
