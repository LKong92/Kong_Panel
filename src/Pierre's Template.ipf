	BZbondaries_x[0]=1
	BZbondaries_y[0]=1/aonb
	BZbondaries_x[1]=-1
	BZbondaries_y[1]=1/aonb
	BZbondaries_x[2]=-1
	BZbondaries_y[2]=-1/aonb
	BZbondaries_x[3]=1
	BZbondaries_y[3]=-1/aonb
	BZbondaries_x[4]=1
	BZbondaries_y[4]=1/aonb
	MBZbondaries_x[0]=0
	MBZbondaries_y[0]=1/aonb
	MBZbondaries_x[1]=-1
	MBZbondaries_y[1]=0
	MBZbondaries_x[2]=0
	MBZbondaries_y[2]=-1/aonb
	MBZbondaries_x[3]=1
	MBZbondaries_y[3]=0/aonb
	MBZbondaries_x[4]=0
	MBZbondaries_y[4]=1/aonb
End
