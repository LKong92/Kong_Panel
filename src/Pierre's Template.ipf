//********************************************************************************************************************************
Proc Constantoffset_n(Shift,number_of_same)
	Variable Shift=1
	Variable number_of_same=1
	Prompt shift, "Input the amount of shift for offset"
	Prompt number_of_same,"Enter the number of graphs with the same offset"
	Constantoffset_nF(Shift,number_of_same)
end
Function Constantoffset_nF(Shift,number_of_same)
	Variable Shift
	Variable number_of_same
	Variable n=0,i
	String WN0
	Variable Y_Offset=0
	Do
		i=0
		Do
			WN0=WaveName("",n+i,1)
			//wave wn0w=$WN0
			ModifyGraph offset($wn0)={0,Y_Offset}
			i+=1
			//display wn0w//**
		While(i<number_of_same)

		Y_Offset+=shift
		n+=number_of_same
		string tc
		tc = WaveName("",n,1)
		wave tcw = $tc
	while( WaveExists( tcw ) != 0 )
End
//********************************************************************************************************************************
Proc color_digimage(matname,disp_or_not)
	String matname
	Variable disp_or_not
	Prompt matname,"Enter the name of the image"
	Prompt disp_or_not,"Do you want to display",popup,"Yes;No"
	PauseUpdate
	Silent 1
	String redname,bluename,greenname
	redname="red_"+matname
	bluename="blue_"+matname
	greenname="green_"+matname
	Make/O/N=(dimsize($matname,0),dimsize($matname,1)) $redname
	Make/O/N=(dimsize($matname,0),dimsize($matname,1)) $bluename
	Make/O/N=(dimsize($matname,0),dimsize($matname,1)) $greenname
	$redname[][]=$matname[p][q][0]
	$bluename[][]=$matname[p][q][2]
	$greenname[][]=$matname[p][q][1]
	If(disp_or_not==1)
		Display;appendimage $redname
		Display;appendimage $bluename
		Display;appendimage $greenname
	Endif
End
