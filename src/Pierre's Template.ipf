Function ButtonCurv_panel(ctrlName) : ButtonControl
	String ctrlName
	String/G curv_name
	If(Wintype("Curvature_panel")==0)
		Execute "Curv_panel_ini()"
		Execute "Curvature_panel()"
		Make/O/N=(1,1) Curvature_matrix
		appendimage Curvature_matrix
		ModifyImage Curvature_matrix ctab= {*,0,Terrain,1}
		Valdisplay valdisp_name Format=curv_name

		else
			Dowindow/F Curvature_panel
	Endif
End
